{
  "name": "neritest-js",
  "version": "0.1.2",
  "description": "A local sandbox that emulates the Nerimity runtime for testing nerimity.js bots without touching production.",
  "author": "Joud j",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JoddabodScripts/neritest.git"
  },
  "homepage": "https://github.com/JoddabodScripts/neritest#readme",
  "bugs": {
    "url": "https://github.com/JoddabodScripts/neritest/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./fixtures": {
      "types": "./dist/fixtures/index.d.ts",
      "import": "./dist/fixtures/index.js",
      "require": "./dist/fixtures/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test \"test/**/*.test.ts\" \"examples/**/*.test.ts\"",
    "test:integration": "node --import tsx --test \"test/integration/**/*.test.ts\"",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "keywords": [
    "nerimity",
    "testing",
    "sandbox",
    "mock",
    "bot",
    "emulator"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "express": "^4.21.2",
    "socket.io": "^4.8.1"
  },
  "peerDependencies": {
    "@nerimity/nerimity.js": ">=1.19.0"
  },
  "peerDependenciesMeta": {
    "@nerimity/nerimity.js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nerimity/nerimity.js": "^1.20.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "marked": "^18.0.5",
    "socket.io-client": "^4.8.1",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "allowScripts": {
    "esbuild@0.27.7": true,
    "esbuild@0.28.1": true
  }
}
